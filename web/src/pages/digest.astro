---
import "../styles/globals.css";
import reviewVenues from "../../public/data/review_venues.json";
import reviewTopPapers from "../../public/data/review_top_papers.json";
import tagRating from "../../public/data/tag_rating.json";
import sleepers from "../../public/data/sleepers.json";
import hot from "../../public/data/hot.json";
import chSources from "../../public/data/ch_sources_summary.json";

const fmt = new Intl.NumberFormat("en-US");
const today = new Date().toISOString().slice(0, 10);

// Quick aggregates for the headline
const totalPapers = chSources.reduce((s: number, r: any) => s + Number(r.n || 0), 0);
const totalReviews = reviewVenues.reduce((s: number, r: any) => s + Number(r.n_reviews || 0), 0);
const topSleepers = sleepers.slice(0, 8);
const topHot = hot.slice(0, 10);
const topTags = tagRating.slice(0, 12);
const topReviewed = reviewTopPapers.slice(0, 8);
---

<html lang="en" class="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>HighSignal — Research Digest, {today}</title>
  </head>
  <body class="bg-background text-foreground min-h-screen">
    <nav class="sticky top-0 z-40 bg-background/80 backdrop-blur-md border-b">
      <div class="max-w-5xl mx-auto px-6 py-3 flex items-center gap-3 text-sm">
        <a href="/" class="font-semibold text-foreground/90 hover:text-primary">researchPapers</a>
        <span class="text-muted-foreground">›</span>
        <span class="font-mono text-xs text-muted-foreground">/digest</span>
        <div class="flex-1"></div>
        <span class="text-xs text-muted-foreground">{today}</span>
      </div>
    </nav>

    <header class="max-w-5xl mx-auto px-6 pt-16 pb-12 text-center">
      <h1 class="text-5xl md:text-6xl font-bold tracking-tight">High<span class="text-primary">Signal</span></h1>
      <p class="mt-6 text-lg text-muted-foreground max-w-2xl mx-auto">
        What the field is paying attention to — distilled from {fmt.format(totalPapers)} papers across arxiv,
        OpenReview, bioRxiv and medRxiv. {fmt.format(totalReviews)} peer reviews aggregated.
      </p>
    </header>

    <section class="max-w-5xl mx-auto px-6 py-8 space-y-4">
      <h2 class="text-2xl font-semibold tracking-tight flex items-center gap-2">
        <span>🌙</span> What reviewers loved that the world hasn't noticed yet
      </h2>
      <p class="text-sm text-muted-foreground">
        Submissions with reviewer rating ≥7 (≥3 reviews) but ≤20 citations. The "sleeper" leaderboard.
      </p>
      <div class="space-y-2">
        {topSleepers.map((p: any) => {
          const oid = p.paper_id.replace(/^openreview:/, "");
          return (
            <a href={`https://openreview.net/forum?id=${oid}`} target="_blank" rel="noopener"
               class="block rounded-lg border bg-card p-4 hover:bg-muted/50 transition-colors">
              <div class="flex items-center gap-3 text-sm mb-1">
                <span class="tabular-nums text-emerald-500 font-semibold">{p.avg_rating.toFixed(2)}</span>
                <span class="text-amber-500 tabular-nums text-xs">{p.citation_count} cites</span>
                <span class="font-mono text-[11px] text-muted-foreground">{p.venue}</span>
                {p.decision && p.decision.toLowerCase().includes("oral") && (
                  <span class="text-[11px] uppercase tracking-wider text-primary">oral</span>
                )}
              </div>
              <div class="text-foreground/90">{p.title}</div>
            </a>
          );
        })}
      </div>
    </section>

    <section class="max-w-5xl mx-auto px-6 py-8 space-y-4">
      <h2 class="text-2xl font-semibold tracking-tight flex items-center gap-2">
        <span>🔥</span> Hot right now
      </h2>
      <p class="text-sm text-muted-foreground">
        Unified ranking: cites/yr × peer-review rating × PageRank.
      </p>
      <div class="space-y-1.5">
        {topHot.map((p: any, i: number) => {
          const url = p.paper_id.startsWith("arxiv:")
            ? `https://arxiv.org/abs/${p.paper_id.replace("arxiv:", "")}`
            : `https://openreview.net/forum?id=${p.paper_id.replace("openreview:", "")}`;
          return (
            <div class="flex items-baseline gap-3 text-sm py-1">
              <span class="text-muted-foreground tabular-nums w-6 text-right">{i + 1}</span>
              <span class="tabular-nums text-orange-400 font-mono w-12 text-xs">{p.hotness.toFixed(2)}</span>
              <a href={url} target="_blank" rel="noopener" class="flex-1 hover:text-primary">
                {p.title}
              </a>
              <span class="text-xs tabular-nums text-muted-foreground">{fmt.format(Math.round(p.cites_per_year))}/yr</span>
            </div>
          );
        })}
      </div>
    </section>

    <section class="max-w-5xl mx-auto px-6 py-8 space-y-4">
      <h2 class="text-2xl font-semibold tracking-tight">Top research areas by reviewer enthusiasm</h2>
      <p class="text-sm text-muted-foreground">
        Mean reviewer rating across papers tagged with each topic. Min 10 papers.
      </p>
      <div class="grid grid-cols-2 md:grid-cols-3 gap-2">
        {topTags.map((t: any) => (
          <div class="rounded-lg border bg-card p-3 text-sm">
            <div class="font-mono text-foreground/90">{t.tag}</div>
            <div class="text-xs text-muted-foreground mt-1">
              <span class="tabular-nums text-emerald-500 font-semibold">{t.mean_rating.toFixed(2)}</span>
              <span class="ml-2 tabular-nums">{t.n_papers} papers</span>
            </div>
          </div>
        ))}
      </div>
    </section>

    <section class="max-w-5xl mx-auto px-6 py-8 space-y-4">
      <h2 class="text-2xl font-semibold tracking-tight">Top-rated accepted submissions (all time)</h2>
      <p class="text-sm text-muted-foreground">From NeurIPS / ICLR / ICML / COLM, ≥3 reviews.</p>
      <div class="space-y-1.5">
        {topReviewed.map((p: any, i: number) => {
          const oid = p.paper_id.replace(/^openreview:/, "");
          return (
            <div class="flex items-baseline gap-3 text-sm py-1">
              <span class="text-muted-foreground tabular-nums w-6 text-right">{i + 1}</span>
              <span class="tabular-nums text-emerald-500 font-semibold w-12 text-xs">{p.avg_rating.toFixed(2)}</span>
              <a href={`https://openreview.net/forum?id=${oid}`} target="_blank" rel="noopener"
                 class="flex-1 hover:text-primary">
                {p.title}
              </a>
              <span class="font-mono text-[10px] text-muted-foreground">{p.venue}</span>
            </div>
          );
        })}
      </div>
    </section>

    <footer class="max-w-5xl mx-auto px-6 py-16 text-center text-xs text-muted-foreground border-t mt-16">
      <p>Generated from a {fmt.format(totalPapers)}-paper multi-source ClickHouse corpus.
         Deployed static data + server-side RAG proxy. Full dashboard: <a href="/" class="hover:text-primary">/</a></p>
    </footer>
  </body>
</html>
